# Copie para .env e ajuste os valores.

# Porta do servidor
PORT=3000

# Segredo usado para assinar os tokens JWT (troque por um valor aleatório longo)
JWT_SECRET=troque-este-segredo-por-uma-string-aleatoria-longa

# Tempo de expiração do token (timeout da sessão do admin). Ex: 15m, 1h, 30m
TOKEN_EXPIRES_IN=15m

# Credenciais do administrador único.
# Gere o hash com: npm run set-admin -- "SuaSenhaForte1!"
# Mantenha o hash entre ASPAS SIMPLES (ele contém '$', que senão é interpretado
# como expansão de variável pelo leitor de .env).
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH='cole-o-hash-aqui'
